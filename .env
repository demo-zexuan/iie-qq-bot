HOST=0.0.0.0  # 监听所有网卡，允许 Docker 容器内的 NapCat 连接宿主机
PORT=8080  # 配置 NoneBot 监听的端口
COMMAND_START=["/"]  # 配置命令起始字符
COMMAND_SEP=["."]  # 配置命令分割字符
ENVIRONMENT=dev
DEBUG=true
TZ=Asia/Shanghai
DRIVER=~fastapi+~httpx+~websockets
ACCESS_TOKEN=abc88488848


# PostgreSQL 配置（支持 docker-compose 环境变量覆盖）
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=iie_qq_bot
PG_USER=postgres
PG_PASSWORD=postgres

# 待统计群号，逗号分隔，例如：123456,234567
GROUP_STATS_GROUP_IDS=1070187533,822841333,1027420558,609475572,820696008
# 每日定时执行时间（24小时制）
GROUP_STATS_DAILY_TIME=13:00
GROUP_STATS_TIMEZONE=Asia/Shanghai
# NapCat API 调用超时时间（秒）
GROUP_STATS_API_TIMEOUT=10
# 消息统计内存缓存刷盘间隔（秒）
GROUP_STATS_MESSAGE_FLUSH_INTERVAL_SECONDS=30
# 每日归档任务执行时间（24 小时制）
GROUP_STATS_ARCHIVE_TIME=03:30
# 明细保留天数（超过后归档并清理）
GROUP_STATS_ARCHIVE_RETENTION_DAYS=30

ONEBOT_ACCESS_TOKEN=abc88488848
ONEBOT_V11_ACCESS_TOKEN=abc88488848