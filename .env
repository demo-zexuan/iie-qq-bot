HOST=0.0.0.0  # 监听所有网卡，允许 Docker 容器内的 NapCat 连接宿主机
PORT=8080  # 配置 NoneBot 监听的端口
COMMAND_START=["/"]  # 配置命令起始字符
COMMAND_SEP=["."]  # 配置命令分割字符
ENVIRONMENT=dev
DEBUG=true
TZ=Asia/Shanghai
DRIVER=~fastapi+~httpx+~websockets
ACCESS_TOKEN=abc88488848


# PostgreSQL 配置（支持 docker-compose 环境变量覆盖）
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=iie_qq_bot
PG_USER=postgres
PG_PASSWORD=postgres

# 待统计群号，逗号分隔，例如：123456,234567
GROUP_STATS_GROUP_IDS=822841333,609475572,1027420558
# 每日定时执行时间（24小时制）
GROUP_STATS_DAILY_TIME=23:59
GROUP_STATS_TIMEZONE=Asia/Shanghai
# NapCat API 调用超时时间（秒）
GROUP_STATS_API_TIMEOUT=10
# 消息统计内存缓存刷盘间隔（秒）
GROUP_STATS_MESSAGE_FLUSH_INTERVAL_SECONDS=30
# 每日归档任务执行时间（24 小时制）
GROUP_STATS_ARCHIVE_TIME=03:30
# 明细保留天数（超过后归档并清理）
GROUP_STATS_ARCHIVE_RETENTION_DAYS=30

# 群引流提示插件，默认关闭；启用后仅在指定群内检测关键词并引用回复
GROUP_GUARD_ENABLED=true
# 需要检测的群号，逗号分隔；修改为你的目标群号
GROUP_GUARD_GROUP_IDS=822841333,1027420558
# 触发关键词，逗号分隔
GROUP_GUARD_KEYWORDS=引,抄,寄,八主任,8主任
# 关键词专属文案，格式：关键词=>文案;;关键词2=>文案2
GROUP_GUARD_KEYWORD_REPLIES=抄=>不如抄底软微，一年冷一年热，27的机会来了;;引=>😡😡😡你们搞引流的就是所奸，你们已经害死杭高兄弟了，还要害死软所兄弟，计算兄弟，信工兄弟，害死网络中心兄弟，害死沈计兄弟，害死绿所兄弟，最后害死自己害死全果壳！😡😡😡😡;;寄=>学历寄存器°，双非考果壳不如考二本;;八主任=>八主任能不能辅导辅导我😭;;8主任=>八主任能不能辅导辅导我😭;;
# 触发后的引用回复内容
GROUP_GUARD_REPLY_TEXT=😡😡😡你们搞引流的就是所奸，你们已经害死杭高兄弟了，还要害死软所兄弟，计算兄弟，信工兄弟，害死网络中心兄弟，害死沈计兄弟，害死绿所兄弟，最后害死自己害死全果壳！😡😡😡😡
# 是否区分大小写，默认不区分
GROUP_GUARD_CASE_SENSITIVE=false
# 全局每个群每分钟最多自动回复几条，0 表示不限流
GROUP_GUARD_MAX_REPLIES_PER_MINUTE=1
# 按群覆盖每分钟自动回复上限，格式：群号:条数,群号2:条数；条数支持 0
GROUP_GUARD_MAX_REPLIES_PER_MINUTE_BY_GROUP=

# 监工插件：在最近 N 分钟滚动窗口内统计白名单群成员消息数，达阈值自动 @ 提醒
SUPERVISOR_ENABLED=false
# 仅监控这些群（白名单），逗号分隔
SUPERVISOR_GROUP_WHITELIST=822841333
# 这些用户不监控（黑名单），逗号分隔；留空表示不排除
SUPERVISOR_USER_BLACKLIST=1287670935,1795863149,2181971908,2065846818,2577539290,3173293792,1489378385,502303255,837399997,1789937038,771612351,2657413849,3242767282,3131810259,2332168485,582040911,3227046016,1721430942,2396901004,1262758849
# 滚动时间窗口大小（分钟），例如 60 表示最近 1 小时
SUPERVISOR_WINDOW_MINUTES=60
# 在滚动时间窗口内达到该消息数后触发提醒
SUPERVISOR_MESSAGE_THRESHOLD=30
# 窗口时区
SUPERVISOR_TIMEZONE=Asia/Shanghai
# 提醒文案模板：支持 {group_id} {user_id} {count} {threshold} {window_minutes}
SUPERVISOR_REMIND_TEMPLATE=你在最近 {window_minutes} 分钟内已发送 {count} 条消息，达到阈值 {threshold} 条，请注意发言频率，多刷几道题吧，兄弟👬🏻，考不考研了？？？

# 王道关键词随机图片插件，默认关闭
WANGDAO_ENABLED=true
# 生效群号白名单，逗号分隔；留空表示所有群
WANGDAO_GROUP_WHITELIST=
# 触发关键词，逗号分隔
WANGDAO_KEYWORDS=王道PUA,王道pua
# 是否区分大小写
WANGDAO_CASE_SENSITIVE=false
# 图片目录（相对项目根目录或绝对路径）
WANGDAO_IMAGE_DIR=wangdao
# 全局默认限流：每个群在滚动时间窗口内最多触发次数
WANGDAO_MAX_TRIGGERS_PER_WINDOW=1
# 全局默认限流窗口时长（秒）
WANGDAO_WINDOW_SECONDS=60
# 按群覆盖限流：格式 群号:次数:秒数，多个用逗号分隔
# 示例：822841333:1:300,1027420558:3:60
WANGDAO_RATE_LIMIT_BY_GROUP=

ONEBOT_ACCESS_TOKEN=abc88488848
ONEBOT_V11_ACCESS_TOKEN=abc88488848

# 日志滚动配置
LOG_FILE_ENABLED=true
LOG_DIR=logs
LOG_FILE_NAME=bot.log
LOG_LEVEL=INFO
# 每天零点切分，可改为 100 MB 等大小策略
LOG_ROTATION=00:00
LOG_RETENTION=14 days
LOG_COMPRESSION=zip

# 可选：强制指定图表中文字体文件（树莓派建议启用）
CHART_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc
